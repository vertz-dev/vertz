{
  "name": "@vertz-examples/linear",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun node_modules/@vertz/cli/dist/vertz.js dev",
    "build": "bun node_modules/@vertz/cli/dist/vertz.js build",
    "codegen": "bun node_modules/@vertz/cli/dist/vertz.js codegen",
    "test": "bun test",
    "typecheck": "bun run codegen && tsc --noEmit",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed"
  },
  "imports": {
    "#generated": "./.vertz/generated/client.ts",
    "#generated/types": "./.vertz/generated/types/index.ts",
    "#generated/schemas": "./.vertz/generated/schemas/index.ts"
  },
  "dependencies": {
    "@vertz/db": "workspace:*",
    "@vertz/errors": "workspace:*",
    "@vertz/fetch": "workspace:*",
    "@vertz/schema": "workspace:*",
    "@vertz/server": "workspace:*",
    "@vertz/theme-shadcn": "workspace:*",
    "@vertz/ui": "workspace:*",
    "@vertz/ui-auth": "workspace:*",
    "@vertz/ui-server": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vertz/cli": "workspace:*",
    "bun-types": "^1.3.9",
    "typescript": "^5.8.0"
  }
}
