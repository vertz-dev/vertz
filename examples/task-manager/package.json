{
  "name": "@vertz-examples/task-manager",
  "version": "0.2.76",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vtz dev",
    "dev:worker": "wrangler dev",
    "build": "vtz build",
    "build:worker": "esbuild src/worker.ts --bundle --format=esm --outfile=dist/worker.js --platform=neutral --target=es2022",
    "start": "vtz start",
    "preview": "vtz run build && vtz run start",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vtz test",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@vertz/errors": "workspace:*",
    "@vertz/fetch": "workspace:*",
    "@vertz/icons": "workspace:*",
    "@vertz/schema": "workspace:*",
    "@vertz/theme-shadcn": "workspace:*",
    "@vertz/ui": "workspace:*",
    "@vertz/ui-primitives": "workspace:*",
    "@vertz/ui-server": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vertz/cli": "workspace:*",
    "@vertz/test": "workspace:*",
    "bun-types": "^1.3.9",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.6.1",
    "typescript": "^5.8.0",
    "wrangler": "^4.65.0"
  }
}
