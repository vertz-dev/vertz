{
  "name": "@vertz/dev-orchestrator",
  "private": true,
  "type": "module",
  "vertz": {
    "title": "Vertz Dev Orchestrator",
    "description": "Internal dogfood app for orchestrating issue planning, implementation, review, and CI monitoring."
  },
  "scripts": {
    "dev": "vtz dev",
    "test": "bun test",
    "typecheck": "vtz exec tsc --noEmit",
    "lint": "vtz exec oxlint src/",
    "lint:fix": "vtz exec oxlint --fix src/",
    "format": "vtz exec oxfmt --check src/",
    "format:fix": "vtz exec oxfmt src/"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.161.0",
    "@img/sharp-darwin-arm64": "^0.34.5",
    "@img/sharp-libvips-darwin-arm64": "^1.2.4",
    "@vertz/agents": "workspace:*",
    "@vertz/icons": "workspace:*",
    "@vertz/schema": "workspace:*",
    "@vertz/server": "workspace:*",
    "@vertz/theme-shadcn": "workspace:*",
    "@vertz/ui": "workspace:*",
    "@vertz/ui-server": "workspace:*",
    "sharp": "^0.34.5",
    "vertz": "workspace:*"
  },
  "devDependencies": {
    "@oxlint/binding-darwin-arm64": "^1.58.0",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.9",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.9.3"
  }
}
