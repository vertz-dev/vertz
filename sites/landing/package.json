{
  "name": "@vertz/landing",
  "private": true,
  "type": "module",
  "vertz": {
    "title": "Vertz — The Agent-Native Framework",
    "description": "One schema derives your database, API, and UI. Fully typed end-to-end. Built for agents to write, humans to ship.",
    "og": {
      "image": "/og.png",
      "url": "https://vertz.dev"
    }
  },
  "scripts": {
    "dev": "bun run src/dev-server.ts",
    "build": "bun node_modules/@vertz/cli/dist/vertz.js build",
    "build:og": "bun run scripts/og-images.ts",
    "deploy": "bun run build && bunx wrangler deploy --define DEPLOY_VERSION:\"'$(date +%s)'\" && bun run scripts/pre-warm.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vertz/icons": "workspace:*",
    "@vertz/theme-shadcn": "workspace:*",
    "@vertz/ui": "workspace:*",
    "@vertz/ui-primitives": "workspace:*",
    "@vertz/ui-server": "workspace:*"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vertz/cli": "workspace:*",
    "@vertz/ui-compiler": "workspace:*",
    "bun-types": "^1.3.9",
    "satori": "^0.25.0",
    "shiki": "^4.0.1",
    "typescript": "^5.8.0"
  }
}
