{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "landing-nextjs",
  "compatibility_date": "2026-03-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./worker/index.ts",
  "assets": {
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "routes": [
    {
      "pattern": "nextjs.vertz.dev",
      "custom_domain": true
    }
  ]
}
