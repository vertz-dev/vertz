{
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "isolatedDeclarations": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["bun-types"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test-d.ts",
    "**/*.test.tsx",
    "**/*.local.ts"
  ],
  "extends": "../../tsconfig.json",
  "include": ["src"]
}
