{
  "name": "@vertz/cli",
  "version": "0.2.58",
  "description": "Vertz CLI — dev, build, create, and deploy commands",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/cli"
  },
  "bin": {
    "vertz": "./dist/vertz.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx bunup && chmod +x dist/vertz.js",
    "test": "vtz test",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@vertz/codegen": "workspace:^",
    "@vertz/compiler": "workspace:^",
    "@vertz/create-vertz-app": "workspace:^",
    "@vertz/db": "workspace:^",
    "@vertz/docs": "workspace:^",
    "@vertz/errors": "workspace:^",
    "@vertz/sqlite": "workspace:*",
    "@vertz/tui": "workspace:^",
    "@vertz/ui-server": "workspace:^",
    "commander": "^14.0.0",
    "esbuild": "^0.25.0",
    "jiti": "^2.4.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@types/node": "^25.3.1",
    "@vertz/test": "workspace:*",
    "bun-types": "^1.3.10",
    "bunup": "^0.16.23",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@vertz/runtime": "^0.2.41",
    "postgres": "^3.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
