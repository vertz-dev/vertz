{
  "name": "@vertz/ui",
  "version": "0.2.60",
  "description": "Vertz UI framework — signals, components, JSX runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "reactivity.json"
  ],
  "type": "module",
  "sideEffects": [
    "dist/shared/*.js"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    },
    "./router": {
      "types": "./dist/router/public.d.ts",
      "import": "./dist/router/public.js"
    },
    "./form": {
      "types": "./dist/form/public.d.ts",
      "import": "./dist/form/public.js"
    },
    "./query": {
      "types": "./dist/query/public.d.ts",
      "import": "./dist/query/public.js"
    },
    "./css": {
      "types": "./dist/css/public.d.ts",
      "import": "./dist/css/public.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.ts",
      "import": "./dist/jsx-runtime/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime/index.d.ts",
      "import": "./dist/jsx-runtime/index.js"
    },
    "./auth": {
      "types": "./dist/auth/public.d.ts",
      "import": "./dist/auth/public.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./reactivity.json": "./reactivity.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "test:benchmark": "vtz test src/dom/__tests__/hydration-deferred-effects-bench.local.ts",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@vertz/fetch": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@vertz/build": "workspace:^",
    "@vertz/schema": "workspace:^",
    "@vertz/test": "workspace:*",
    "happy-dom": "^20.7.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
