{
  "name": "@vertz/cloudflare",
  "version": "0.2.69",
  "description": "Cloudflare Workers adapter for vertz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vertz-dev/vertz.git",
    "directory": "packages/cloudflare"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./image": {
      "types": "./dist/image-optimizer.d.ts",
      "import": "./dist/image-optimizer.js"
    },
    "./tpr": {
      "types": "./dist/tpr.d.ts",
      "import": "./dist/tpr.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsgo --noEmit",
    "test": "vtz test"
  },
  "dependencies": {
    "@vertz/core": "workspace:^"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@vertz/test": "workspace:*",
    "@vertz/ui-server": "workspace:^",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@vertz/ui-server": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@vertz/ui-server": {
      "optional": true
    }
  }
}
