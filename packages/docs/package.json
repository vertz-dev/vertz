{
  "name": "@vertz/docs",
  "version": "0.1.2",
  "description": "Documentation framework for Vertz — build docs with MDX, deploy to Cloudflare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/docs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bunup",
    "test": "vtz test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "@shikijs/rehype": "^4.0.2",
    "@vertz/errors": "workspace:^",
    "@vertz/mdx": "workspace:^",
    "@vertz/ui": "workspace:^",
    "lucide-static": "^1.7.0",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@types/bun": "latest",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.3.1",
    "@types/unist": "^3.0.3",
    "@vertz/test": "workspace:*",
    "@vertz/ui-server": "workspace:^",
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "happy-dom": "^20.7.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
