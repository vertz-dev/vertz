    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vertz/test": "workspace:*",
    "bunup": "^0.16.31",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
