{
  "name": "@vertz/errors",
  "version": "0.2.55",
  "description": "Unified error taxonomy for Vertz - Result types, domain errors, and mapping utilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/errors"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
