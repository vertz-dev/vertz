{
  "name": "@vertz/fetch",
  "version": "0.2.67",
  "description": "Type-safe HTTP client for Vertz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/fetch"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@vertz/errors": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vertz/build": "workspace:^",
    "@vertz/test": "workspace:*",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
