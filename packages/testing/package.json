    "@vertz/server": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vertz/build": "workspace:^",
    "@vertz/schema": "workspace:^",
    "@vertz/test": "workspace:*",
    "bun-types": "^1.3.10",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
