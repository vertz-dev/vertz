{
  "name": "@vertz/db",
  "version": "0.2.55",
  "description": "Database layer for Vertz — typed queries, migrations, codegen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/db"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sql": {
      "types": "./dist/sql/index.d.ts",
      "import": "./dist/sql/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./diagnostic": {
      "types": "./dist/diagnostic/index.d.ts",
      "import": "./dist/diagnostic/index.js"
    },
    "./schema-derive": {
      "types": "./dist/schema-derive/index.d.ts",
      "import": "./dist/schema-derive/index.js"
    },
    "./postgres": {
      "types": "./dist/index.d.ts",
      "import": "./dist/postgres/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx bunup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@vertz/errors": "workspace:^",
    "@vertz/schema": "workspace:^",
    "nanoid": "^5.1.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@electric-sql/pglite": "^0.3.14",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.3.1",
    "better-sqlite3": "^12.6.2",
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "postgres": "^3.4.8",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.0.0",
    "postgres": "^3.4.8"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
