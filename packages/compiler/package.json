{
  "name": "@vertz/compiler",
  "version": "0.2.67",
  "description": "Vertz compiler — internal, no stability guarantee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/compiler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vertz/build": "workspace:^",
    "@vertz/test": "workspace:*",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
