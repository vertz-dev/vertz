{
  "name": "@vertz/ui-primitives",
  "version": "0.2.69",
  "description": "Headless UI primitives for Vertz — Accordion, Dialog, Select, and more",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/ui-primitives"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
