{
  "name": "@vertz/og",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "description": "Framework-level Open Graph image generation for Vertz — component to PNG via Satori + resvg",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/og"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.25.0"
  },
  "peerDependencies": {
    "@resvg/resvg-wasm": "^2.6.2"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false
}
