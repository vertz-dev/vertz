{
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "isolatedDeclarations": true,
    "jsx": "react",
    "jsxFactory": "h",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test-d.ts"
  ],
  "extends": "../../tsconfig.json",
  "include": ["src"]
}
