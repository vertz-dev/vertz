{
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "isolatedDeclarations": true,
    "jsx": "react",
    "jsxFactory": "h",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"]
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "**/*.test-d.ts"],
  "extends": "../../tsconfig.json",
  "include": ["src"]
}
