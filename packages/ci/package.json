{
  "name": "@vertz/ci",
  "version": "0.2.47",
  "description": "TypeScript SDK for vtz ci — define tasks, workflows, and caching for monorepo CI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/ci"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./loader": {
      "import": "./dist/loader.js",
      "types": "./dist/loader.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
