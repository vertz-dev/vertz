{
  "name": "@vertz/ui-compiler",
  "version": "0.2.42",
  "description": "Vertz UI compiler — SSR and build-time optimizations",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/ui-compiler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@vertz/ui": "workspace:^",
    "magic-string": "^0.30.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@types/node": "^25.3.1",
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
