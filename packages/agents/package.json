{
  "name": "@vertz/agents",
  "version": "0.2.48",
  "description": "Declarative AI agent framework for Vertz — agents, tools, and workflows on Cloudflare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/agents"
  },
  "files": [
    "dist",
    "migrations"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cloudflare": {
      "import": "./dist/cloudflare.js",
      "types": "./dist/cloudflare.d.ts"
    },
    "./entities": {
      "import": "./dist/entities/index.js",
      "types": "./dist/entities/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@vertz/errors": "workspace:^",
    "@vertz/schema": "workspace:^",
    "@vertz/sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vertz/build": "workspace:^",
    "@vertz/db": "workspace:^",
    "@vertz/server": "workspace:^",
    "@vertz/test": "workspace:*",
    "bun-types": "^1.3.10",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@vertz/db": "workspace:^",
    "@vertz/server": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@vertz/db": {
      "optional": true
    },
    "@vertz/server": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
