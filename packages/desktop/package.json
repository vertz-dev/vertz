{
  "name": "@vertz/desktop",
  "version": "0.2.54",
  "description": "Type-safe desktop APIs for Vertz native webview — filesystem, shell, clipboard, dialogs, window control",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/desktop"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx bunup",
    "test": "echo 'type-level tests only — validated via typecheck'",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@vertz/errors": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vertz/test": "workspace:*",
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
