{
  "name": "@vertz/test",
  "version": "0.2.79",
  "description": "Type declarations and runtime stubs for the Vertz test framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/test"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc --outDir dist --declaration",
    "test": "vtz test",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "bun-types": "^1.3.10",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
