{
  "name": "@vertz/icons",
  "version": "0.2.77",
  "description": "Tree-shakeable Lucide icon components for Vertz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/icons"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "generate": "vtz run scripts/generate.ts",
    "test": "vtz test",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@vertz/build": "workspace:^",
    "@vertz/test": "workspace:*",
    "happy-dom": "^20.7.0",
    "lucide-static": "^0.575.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
