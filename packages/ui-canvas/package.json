{
  "name": "@vertz/ui-canvas",
  "version": "0.2.75",
  "description": "Vertz Canvas renderer with PixiJS and signals",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/ui-canvas"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "test:benchmark": "vtz test src/graphics-benchmark.local.ts",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@vertz/build": "workspace:^",
    "@vertz/test": "workspace:*",
    "@vertz/ui": "workspace:^",
    "happy-dom": "^20.7.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@vertz/ui": "workspace:^"
  },
  "engines": {
    "node": ">=22"
  }
}
