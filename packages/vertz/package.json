{
  "name": "vertz",
  "version": "0.2.45",
  "description": "The first TypeScript stack built for LLMs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/vertz"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./db": {
      "import": "./dist/db.js",
      "types": "./dist/db.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.js",
      "types": "./dist/ui.d.ts"
    },
    "./ui-compiler": {
      "import": "./dist/ui-compiler.js",
      "types": "./dist/ui-compiler.d.ts"
    },
    "./fetch": {
      "import": "./dist/fetch.js",
      "types": "./dist/fetch.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./cloudflare": {
      "import": "./dist/cloudflare.js",
      "types": "./dist/cloudflare.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    },
    "./ui-primitives": {
      "import": "./dist/ui-primitives.js",
      "types": "./dist/ui-primitives.d.ts"
    },
    "./ui-server": {
      "import": "./dist/ui-server.js",
      "types": "./dist/ui-server.d.ts"
    },
    "./ui-server/bun-plugin": {
      "import": "./dist/ui-server-bun-plugin.js",
      "types": "./dist/ui-server-bun-plugin.d.ts"
    },
    "./ui-auth": {
      "import": "./dist/ui-auth.js",
      "types": "./dist/ui-auth.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@vertz/cloudflare": "workspace:^",
    "@vertz/db": "workspace:^",
    "@vertz/errors": "workspace:^",
    "@vertz/fetch": "workspace:^",
    "@vertz/schema": "workspace:^",
    "@vertz/server": "workspace:^",
    "@vertz/testing": "workspace:^",
    "@vertz/tui": "workspace:^",
    "@vertz/ui": "workspace:^",
    "@vertz/ui-auth": "workspace:^",
    "@vertz/ui-primitives": "workspace:^",
    "@vertz/ui-server": "workspace:^"
  },
  "devDependencies": {}
}
