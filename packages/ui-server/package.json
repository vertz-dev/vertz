{
  "name": "@vertz/ui-server",
  "version": "0.2.55",
  "description": "Vertz UI server-side rendering runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/ui-server"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ssr": {
      "import": "./dist/ssr/index.js",
      "types": "./dist/ssr/index.d.ts"
    },
    "./dom-shim": {
      "import": "./dist/dom-shim/index.js",
      "types": "./dist/dom-shim/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime/index.js",
      "types": "./dist/jsx-runtime/index.d.ts"
    },
    "./bun-plugin": {
      "import": "./dist/bun-plugin/index.js",
      "types": "./dist/bun-plugin/index.d.ts"
    },
    "./fast-refresh-runtime": {
      "import": "./dist/bun-plugin/fast-refresh-runtime.js",
      "types": "./dist/bun-plugin/fast-refresh-runtime.d.ts"
    },
    "./state-inspector": {
      "import": "./dist/bun-plugin/state-inspector.js",
      "types": "./dist/bun-plugin/state-inspector.d.ts"
    },
    "./bun-dev-server": {
      "import": "./dist/bun-dev-server.js",
      "types": "./dist/bun-dev-server.d.ts"
    },
    "./fetch-scope": {
      "import": "./dist/fetch-scope.js",
      "types": "./dist/fetch-scope.d.ts"
    },
    "./node": {
      "import": "./dist/node-handler.js",
      "types": "./dist/node-handler.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx bunup",
    "test": "bun test --timeout 60000 src/",
    "test:integration": "bun test src/__tests__/bun-dev-server.integration.local.ts",
    "test:e2e": "bunx playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@capsizecss/unpack": "^4.0.0",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@vertz/core": "workspace:^",
    "@vertz/ui": "workspace:^",
    "magic-string": "^0.30.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@playwright/test": "^1.58.2",
    "@vertz/codegen": "workspace:^",
    "@vertz/test": "workspace:*",
    "bun-types": "^1.3.10",
    "bunup": "^0.16.31",
    "happy-dom": "^20.8.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
