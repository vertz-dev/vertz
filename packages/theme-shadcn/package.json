{
  "name": "@vertz/theme-shadcn",
  "version": "0.2.65",
  "description": "Shadcn-inspired theme for Vertz — pre-built style definitions using variants() and css()",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/theme-shadcn"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "import": "./dist/base.js"
    },
    "./configs": {
      "types": "./dist/configs.d.ts",
      "import": "./dist/configs.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "test:watch": "vtz test --watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@vertz/ui": "workspace:^",
    "@vertz/ui-primitives": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@vertz/build": "workspace:^",
    "@vertz/test": "workspace:*",
    "@vertz/ui-server": "workspace:^",
    "happy-dom": "^20.7.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
