{
  "$schema": "https://mintlify.com/docs.json",
  "colors": {
    "dark": "#2563eb",
    "light": "#60a5fa",
    "primary": "#3b82f6"
  },
  "favicon": "/favicon.svg",
  "footer": {
    "socials": {
      "github": "https://github.com/vertz-dev/vertz",
      "x": "https://x.com/veraborgesv"
    }
  },
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "name": "Vertz",
