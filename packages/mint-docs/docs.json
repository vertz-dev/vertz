    {
      "destination": "/guides/ui/component-library",
      "source": "/guides/components"
    },
    {
      "destination": "/guides/ui/component-library",
      "source": "/guides/ui/components-list"
    },
    {
      "destination": "/philosophy",
      "source": "/vision"
    },
    {
      "destination": "/philosophy",
      "source": "/manifesto"
    }
  ],
  "theme": "mint",
  "llmsTxt": {
    "enabled": true
  }
