            "pages": [
              "guides/ui/overview",
              "guides/ui/components",
              "guides/ui/component-library",
              "guides/ui/reactivity",
              "guides/ui/styling",
              "guides/ui/routing",
              "guides/ui/data-fetching",
              "guides/ui/auto-field-selection",
              "guides/ui/forms",
              "guides/ui/auth",
              "guides/ui/multi-tenancy",
              "guides/ui/ssr",
              "guides/ui/access-control"
            ]
          },
          {
            "group": "vertz/ui-compiler",
            "pages": ["guides/ui/compiler"]
          },
          {
            "group": "vertz/icons",
            "pages": ["guides/ui/icons"]
          },
          {
            "group": "vertz/schema",
            "pages": ["guides/schema"]
          },
          {
            "group": "vertz/errors",
            "pages": ["guides/errors"]
          },
          {
            "group": "vertz/server",
            "pages": [
              "guides/server/overview",
              "guides/server/entities",
              "guides/server/domains",
              "guides/server/entity-exposure",
              "guides/server/auth",
              "guides/server/multi-tenancy",
              "guides/server/codegen",
              "guides/server/oauth",
              "guides/server/services",
              "guides/env"
            ]
          },
          {
            "group": "vertz/agents",
            "pages": ["guides/agents/overview", "guides/agents/workflows"]
          },
          {
            "group": "vertz/db",
            "pages": [
              "guides/db/overview",
              "guides/db/schema",
              "guides/db/queries",
              "guides/db/migrations",
              "guides/db/introspection",
              "guides/db/seeding"
            ]
          },
          {
            "group": "vertz/fetch",
            "pages": ["guides/fetch"]
          },
          {
            "group": "Deployment",
            "pages": [
              "guides/deploy/cloudflare",
              "guides/deploy/node",
              "guides/deploy/static-sites",
