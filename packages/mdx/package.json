{
  "name": "@vertz/mdx",
  "version": "0.1.0",
  "description": "MDX support for Vertz — Bun plugin that compiles .mdx files to Vertz components",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz.git",
    "directory": "packages/mdx"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vtzx vertz-build",
    "test": "vtz test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "@shikijs/rehype": "^4.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^4.0.0",
    "shiki": "^4.0.1",
    "unified": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.1",
    "@vertz/test": "workspace:*",
    "@vertz/ui-server": "workspace:^",
    "bun-types": "^1.3.10",
    "@vertz/build": "workspace:^",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
