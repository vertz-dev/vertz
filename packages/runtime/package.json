{
  "name": "@vertz/runtime",
  "version": "0.2.50",
  "description": "Vertz runtime binary — internal platform selector for vtz CLI. Use @vertz/cli for development.",
  "repository": {
    "type": "git",
    "url": "https://github.com/vertz-dev/vertz"
  },
  "bin": {
    "vertz": "./cli.js",
    "vtz": "./cli.js",
    "vtzx": "./cli-exec.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "postinstall.cjs",
    "cli.js",
    "cli-exec.js"
  ],
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vtzx bun build index.ts --outdir . --target node",
    "postinstall": "node postinstall.cjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.32"
  },
  "optionalDependencies": {
    "@vertz/runtime-darwin-arm64": "0.2.50",
    "@vertz/runtime-darwin-x64": "0.2.50",
    "@vertz/runtime-linux-arm64": "0.2.50",
    "@vertz/runtime-linux-x64": "0.2.50"
  }
}
